@model AspNetCoreCrudMongo.Models.Cliente  
<!-- ← Sua model Cliente -->

@{
    ViewData["Title"] = "Confirmar Deleção";
}

<div class="container">
    <h1>Confirmar Deleção</h1>
    <h3>Tem certeza que quer deletar este cliente?</h3>
    
    <div>
        <h4>Cliente #@Model.Id</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Nome)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Nome)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Senha)
            </dt>
            <dd class="col-sm-10">
                <span class="text-muted">********</span>  <!-- ← Senha oculta -->
            </dd>
        </dl>
        
        <!-- Formulário confirmação -->
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />  <!-- ← Campo oculto com ID -->
            <input type="submit" value="Deletar" class="btn btn-danger" /> &nbsp;
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>