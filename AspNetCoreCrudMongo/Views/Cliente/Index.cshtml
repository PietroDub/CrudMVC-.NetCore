@model IEnumerable<AspNetCoreCrudMongo.Models.Cliente>  
<!-- ← Sua model Lista<Cliente> -->

@{
    ViewData["Title"] = "Lista de Clientes";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Lista de Clientes</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Novo Cliente
        </a>
    </div>

    <!-- Tabela responsiva -->
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>ID</th>
                    <th>
                        @Html.DisplayNameFor(model => model.Nome)
                    </th>
                    <th>Senha</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
@foreach (var item in Model) {
                <tr>
                    <td>
                        <code>@Html.DisplayFor(modelItem => item.Id)</code>
                    </td>
                    <td>
                        <strong>@Html.DisplayFor(modelItem => item.Nome)</strong>
                    </td>
                    <td>
                        <span class="badge badge-secondary">********</span>  <!-- ← Senha oculta -->
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <a asp-action="Details" asp-route-id="@item.Id" 
                               class="btn btn-info btn-sm" title="Detalhes">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" 
                               class="btn btn-warning btn-sm" title="Editar">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" 
                               class="btn btn-danger btn-sm" title="Deletar">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
}
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center mt-4">
            <h4>Nenhum cliente cadastrado</h4>
            <p><a asp-action="Create">Crie o primeiro agora!</a></p>
        </div>
    }
</div>